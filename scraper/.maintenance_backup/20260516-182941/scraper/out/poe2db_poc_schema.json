{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PoE2DB Planner POC Data",
  "type": "object",
  "required": [
    "schemaVersion",
    "parserVersion",
    "generatedAt",
    "source",
    "sourceUrls",
    "items",
    "augment",
    "itemClasses",
    "itemSubtypes",
    "normalExplicitPools",
    "editorModifierPools"
  ],
  "properties": {
    "schemaVersion": {
      "const": "poc-0.21"
    },
    "parserVersion": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "source": {
      "const": "poe2db"
    },
    "sourceUrls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "items": {
      "type": "array"
    },
    "augment": {
      "type": "object"
    },
    "augments": {
      "type": "array"
    },
    "itemClasses": {
      "type": "array"
    },
    "itemSubtypes": {
      "type": "array"
    },
    "normalExplicitPools": {
      "type": "array"
    },
    "editorModifierPools": {
      "type": "array"
    },
    "modifierSourceMechanics": {
      "type": "array"
    },
    "modifierAudits": {
      "type": "array"
    },
    "baseItems": {
      "type": "array"
    },
    "uniqueItems": {
      "type": "array"
    },
    "uniqueGloves": {
      "type": "array"
    },
    "uniqueBoots": {
      "type": "array"
    },
    "uniqueHelmets": {
      "type": "array"
    },
    "dataSnapshots": {
      "type": "array"
    },
    "parserSanity": {
      "type": "object"
    },
    "payloadHealth": {
      "type": "object"
    }
  },
  "additionalProperties": false
}